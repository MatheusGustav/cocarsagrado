/*.html
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate

# no-cache (e não max-age=0): o Browser Cache TTL da zona Cloudflare (4h)
# sobrepõe qualquer max-age menor, mas respeita no-cache — o navegador
# revalida via ETag a cada visita (304 se não mudou). Dispensa bump de ?v=.
/*.css
  Cache-Control: no-cache, must-revalidate

/*.js
  Cache-Control: no-cache, must-revalidate

/data/*
  Cache-Control: no-cache, must-revalidate


/images/logo3-192.png
  Cache-Control: public, max-age=31536000, immutable

/images/logo3.png
  Cache-Control: public, max-age=31536000, immutable
